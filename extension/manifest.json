{
  "manifest_version": 3,
  "name": "KTP Auto-Crop",
  "version": "1.0.0",
  "description": "Foto KTP dari kamera/galeri, auto-crop, lalu download tanpa server.",
  "permissions": ["downloads", "storage"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "KTP Auto-Crop",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
